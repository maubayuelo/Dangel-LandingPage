# ── GraphQL / WordPress ───────────────────────────────────────────────────────
# Local development (Local by Flywheel):
VITE_GRAPHQL_URI=http://dangelwellness.local/graphql
# Production CMS:
# VITE_GRAPHQL_URI=https://cms.dangelwellness.ca/graphql

# ── EmailJS (contact form) ────────────────────────────────────────────────────
# Get these from https://www.emailjs.com → Account → API Keys / Email Services
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_auto_reply_template_id
VITE_EMAILJS_NOTIFICATION_TEMPLATE_ID=your_notification_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
